<%- include('partials/header') %>

<!-- Dashboard Title -->
<div class="mb-6">
  <h1 class="text-2xl font-bold tracking-tight text-white">Fleet Management</h1>
  <p class="text-sm text-slate-400">Monitor vehicle statuses, driver assignments, and log telematics.</p>
</div>

<!-- Quick Statistics Grid -->
<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
  <!-- Total Vehicles -->
  <div class="p-4 rounded-2xl glass-panel flex items-center justify-between border border-slate-800/40">
    <div>
      <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Total Vehicles</span>
      <span class="text-2xl font-bold text-white"><%= stats.totalVehicles %></span>
    </div>
    <div class="w-10 h-10 rounded-xl bg-blue-500/10 border border-blue-500/20 flex items-center justify-center text-blue-400">
      <i class="fa-solid fa-truck-moving text-sm"></i>
    </div>
  </div>

  <!-- Active Vehicles -->
  <div class="p-4 rounded-2xl glass-panel flex items-center justify-between border border-slate-800/40">
    <div>
      <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Active</span>
      <span class="text-2xl font-bold text-emerald-400"><%= stats.activeVehicles %></span>
    </div>
    <div class="w-10 h-10 rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
      </span>
    </div>
  </div>

  <!-- Inactive Vehicles -->
  <div class="p-4 rounded-2xl glass-panel flex items-center justify-between border border-slate-800/40">
    <div>
      <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Inactive</span>
      <span class="text-2xl font-bold text-slate-400"><%= stats.inactiveVehicles %></span>
    </div>
    <div class="w-10 h-10 rounded-xl bg-slate-500/10 border border-slate-500/20 flex items-center justify-center text-slate-400 font-bold">
      <i class="fa-solid fa-power-off text-sm"></i>
    </div>
  </div>

  <!-- Maintenance Vehicles -->
  <div class="p-4 rounded-2xl glass-panel flex items-center justify-between border border-slate-800/40">
    <div>
      <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Maintenance</span>
      <span class="text-2xl font-bold text-amber-500"><%= stats.maintenanceVehicles %></span>
    </div>
    <div class="w-10 h-10 rounded-xl bg-amber-500/10 border border-amber-500/20 flex items-center justify-center text-amber-500">
      <i class="fa-solid fa-screwdriver-wrench text-sm"></i>
    </div>
  </div>

  <!-- Total Drivers -->
  <div class="p-4 rounded-2xl glass-panel flex items-center justify-between border border-slate-800/40">
    <div>
      <span class="text-slate-500 text-[10px] font-bold uppercase tracking-wider block mb-1">Total Drivers</span>
      <span class="text-2xl font-bold text-white"><%= stats.totalDrivers %></span>
    </div>
    <div class="w-10 h-10 rounded-xl bg-purple-500/10 border border-purple-500/20 flex items-center justify-center text-purple-400">
      <i class="fa-solid fa-user-tie text-sm"></i>
    </div>
  </div>
</div>



<div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
  
  <!-- Left Side: Fleet List Table, Search, and Pagination -->
  <div class="lg:col-span-2 space-y-6">
    
    <!-- Controls (Search & Filters) -->
    <div class="p-4 rounded-2xl glass-panel flex flex-col sm:flex-row gap-4 items-center justify-between">
      <form action="/fleets" method="GET" class="w-full sm:w-auto flex items-center gap-2 flex-1">
        <div class="relative w-full max-w-md">
          <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
            <i class="fa-solid fa-magnifying-glass text-xs"></i>
          </span>
          <input 
            type="text" 
            name="search" 
            value="<%= search %>" 
            placeholder="Search by license plate or driver..." 
            class="w-full pl-10 pr-4 py-2 rounded-xl bg-slate-950/40 border border-slate-800/80 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-blue-500/50 transition-all-300"
          >
        </div>
        <button 
          type="submit" 
          class="px-4 py-2 rounded-xl bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold shadow-md shadow-blue-600/10 transition-all-300"
        >
          Search
        </button>
        <% if (search) { %>
          <a 
            href="/fleets" 
            class="px-3 py-2 rounded-xl bg-slate-800 hover:bg-slate-700 text-slate-400 text-xs font-semibold transition-all-300"
          >
            Clear
          </a>
        <% } %>
      </form>
      
      <!-- Counter info -->
      <span class="text-xs text-slate-500 shrink-0">
        Showing <%= fleets.length %> of <%= meta.totalItems %> items
      </span>
    </div>

    <!-- Fleet Data Table Card -->
    <div class="rounded-2xl glass-panel overflow-hidden shadow-2xl">
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-left">
          <thead>
            <tr class="border-b border-slate-800/60 bg-slate-900/10 text-slate-400 text-xs uppercase tracking-wider font-semibold">
              <th class="px-6 py-4">License Plate</th>
              <th class="px-6 py-4">Vehicle Type</th>
              <th class="px-6 py-4">Driver Name</th>
              <th class="px-6 py-4">Status</th>
              <th class="px-6 py-4 text-right">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-800/40 text-sm">
            <% if (fleets.length === 0) { %>
              <tr>
                <td colspan="5" class="px-6 py-12 text-center text-slate-500">
                  <i class="fa-solid fa-truck text-3xl mb-3 block"></i>
                  No fleets registered matching your criteria.
                </td>
              </tr>
            <% } else { %>
              <% fleets.forEach(fleet => { %>
                <tr class="hover:bg-slate-900/20 transition-all duration-150">
                  <!-- License Plate -->
                  <td class="px-6 py-4 font-semibold text-white">
                    <a href="/fleets/<%= fleet.id %>" class="flex items-center gap-2 hover:text-blue-400 transition-all-300">
                      <span class="px-2 py-0.5 rounded bg-slate-800 text-[11px] font-mono text-slate-300 tracking-wider border border-slate-700/60"><%= fleet.license_plate %></span>
                    </a>
                  </td>
                  
                  <!-- Vehicle Type -->
                  <td class="px-6 py-4 text-slate-300">
                    <span class="flex items-center gap-2">
                      <% if (fleet.vehicle_type === 'Wingbox') { %>
                        <i class="fa-solid fa-box text-blue-400 text-xs"></i>
                      <% } else if (fleet.vehicle_type === 'Blind Van') { %>
                        <i class="fa-solid fa-truck-ramp-box text-purple-400 text-xs"></i>
                      <% } else { %>
                        <i class="fa-solid fa-truck-moving text-amber-400 text-xs"></i>
                      <% } %>
                      <%= fleet.vehicle_type %>
                    </span>
                  </td>
                  
                  <!-- Driver -->
                  <td class="px-6 py-4 text-slate-300">
                    <%= fleet.driver_name %>
                  </td>
                  
                  <!-- Status Badges -->
                  <td class="px-6 py-4">
                    <% if (fleet.status === 'Active') { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse"></span>
                        Active
                      </span>
                    <% } else if (fleet.status === 'Maintenance') { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                        Maintenance
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-slate-500/10 text-slate-400 border border-slate-500/20">
                        <span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>
                        Inactive
                      </span>
                    <% } %>
                  </td>
                  
                  <!-- Actions -->
                  <td class="px-6 py-4 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a 
                        href="/fleets/<%= fleet.id %>" 
                        class="p-1.5 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800 transition-all-300"
                        title="View Telematics Timeline"
                      >
                        <i class="fa-solid fa-gauge-high text-xs"></i>
                      </a>
                      
                      <!-- Delete form submission -->
                      <form action="/fleets/<%= fleet.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this vehicle?');">
                        <button 
                          type="submit" 
                          class="p-1.5 rounded-lg text-slate-500 hover:text-red-400 hover:bg-red-500/10 transition-all-300"
                          title="Delete Fleet"
                          <%= fleet.status === 'Active' ? 'disabled' : '' %>
                        >
                          <i class="fa-regular fa-trash-can text-xs <%= fleet.status === 'Active' ? 'opacity-30 cursor-not-allowed' : '' %>"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Pagination Controls -->
    <% if (meta.totalPages > 1) { %>
      <div class="flex items-center justify-between py-2">
        <span class="text-xs text-slate-500">
          Page <%= meta.currentPage %> of <%= meta.totalPages %>
        </span>
        <div class="flex items-center gap-1.5">
          <!-- Previous Button -->
          <% if (meta.currentPage > 1) { %>
            <a 
              href="/fleets?search=<%= search %>&page=<%= meta.currentPage - 1 %>&limit=<%= meta.itemsPerPage %>" 
              class="px-3.5 py-1.5 rounded-xl bg-slate-900 border border-slate-800/80 text-xs font-semibold text-slate-300 hover:text-white hover:border-slate-700 transition-all-300"
            >
              <i class="fa-solid fa-chevron-left mr-1"></i> Previous
            </a>
          <% } else { %>
            <span class="px-3.5 py-1.5 rounded-xl bg-slate-900/40 border border-slate-800/40 text-xs font-semibold text-slate-600 cursor-not-allowed">
              <i class="fa-solid fa-chevron-left mr-1"></i> Previous
            </span>
          <% } %>

          <!-- Next Button -->
          <% if (meta.currentPage < meta.totalPages) { %>
            <a 
              href="/fleets?search=<%= search %>&page=<%= meta.currentPage + 1 %>&limit=<%= meta.itemsPerPage %>" 
              class="px-3.5 py-1.5 rounded-xl bg-slate-900 border border-slate-800/80 text-xs font-semibold text-slate-300 hover:text-white hover:border-slate-700 transition-all-300"
            >
              Next <i class="fa-solid fa-chevron-right ml-1"></i>
            </a>
          <% } else { %>
            <span class="px-3.5 py-1.5 rounded-xl bg-slate-900/40 border border-slate-800/40 text-xs font-semibold text-slate-600 cursor-not-allowed">
              Next <i class="fa-solid fa-chevron-right ml-1"></i>
            </span>
          <% } %>
        </div>
      </div>
    <% } %>

  </div>

  <!-- Right Side: Register New Fleet Card -->
  <div>
    <div class="rounded-2xl glass-panel p-6 shadow-2xl space-y-6 sticky top-6 border border-slate-800/50">
      <div>
        <h2 class="text-base font-bold text-white flex items-center gap-2">
          <i class="fa-solid fa-plus text-blue-500"></i>
          Register New Vehicle
        </h2>
        <p class="text-xs text-slate-400 mt-1">Add a new logistic vehicle unit to the FleetPulse database.</p>
      </div>

      <form action="/fleets" method="POST" class="space-y-4">
        <!-- License Plate -->
        <div>
          <label for="license_plate" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">License Plate</label>
          <input 
            type="text" 
            name="license_plate" 
            id="license_plate" 
            required 
            placeholder="e.g. L 1234 AB" 
            class="w-full px-3.5 py-2.5 rounded-xl bg-slate-950/40 border border-slate-850 text-xs text-white placeholder-slate-600 focus:outline-none focus:border-blue-500/50 transition-all-300 font-mono tracking-wider"
          >
        </div>

        <!-- Vehicle Type -->
        <div>
          <label for="vehicle_type" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Vehicle Type</label>
          <select 
            name="vehicle_type" 
            id="vehicle_type" 
            required 
            class="w-full px-3.5 py-2.5 rounded-xl bg-slate-950/40 border border-slate-850 text-xs text-white focus:outline-none focus:border-blue-500/50 transition-all-300"
          >
            <% vehicleTypes.forEach(type => { %>
              <option value="<%= type %>" class="bg-slate-950 text-slate-200"><%= type %></option>
            <% }) %>
          </select>
        </div>

        <!-- Driver Name -->
        <div>
          <label for="driver_name" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Driver Name</label>
          <input 
            type="text" 
            name="driver_name" 
            id="driver_name" 
            required 
            placeholder="e.g. Robert Smith" 
            class="w-full px-3.5 py-2.5 rounded-xl bg-slate-950/40 border border-slate-850 text-xs text-white placeholder-slate-600 focus:outline-none focus:border-blue-500/50 transition-all-300"
          >
        </div>

        <!-- Initial Status -->
        <div>
          <label for="status" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1.5">Initial Status</label>
          <select 
            name="status" 
            id="status" 
            required 
            class="w-full px-3.5 py-2.5 rounded-xl bg-slate-950/40 border border-slate-850 text-xs text-white focus:outline-none focus:border-blue-500/50 transition-all-300"
          >
            <% fleetStatuses.forEach(st => { %>
              <option value="<%= st %>" class="bg-slate-950 text-slate-200" <%= st === 'Inactive' ? 'selected' : '' %>><%= st %></option>
            <% }) %>
          </select>
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          class="w-full py-3 rounded-xl bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white text-xs font-semibold shadow-md shadow-blue-500/10 hover:shadow-blue-500/20 active:scale-[0.98] transition-all-300"
        >
          Add Vehicle Unit
        </button>
      </form>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
