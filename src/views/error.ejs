<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error — FleetPulse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Plus Jakarta Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #050811;
      background-image: 
        radial-gradient(at 10% 20%, rgba(239, 68, 68, 0.08) 0px, transparent 50%),
        radial-gradient(at 90% 80%, rgba(99, 102, 241, 0.08) 0px, transparent 50%);
    }
    .glass-card {
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
  </style>
</head>
<body class="h-full flex items-center justify-center p-4 antialiased">
  
  <div class="w-full max-w-md text-center">
    
    <!-- Error Icon -->
    <div class="inline-flex w-16 h-16 rounded-2xl bg-red-500/10 border border-red-500/20 items-center justify-center text-red-400 mb-6 shadow-xl shadow-red-500/5">
      <i class="fa-solid fa-triangle-exclamation text-2xl"></i>
    </div>

    <!-- Error Card -->
    <div class="glass-card rounded-3xl p-8 shadow-2xl text-left">
      <div class="flex items-center justify-between mb-4">
        <h1 class="text-xl font-bold text-white">Application Exception</h1>
        <span class="text-xs font-mono px-2.5 py-1 rounded-full bg-red-500/10 text-red-400 border border-red-500/20 font-semibold"><%= statusCode %></span>
      </div>

      <p class="text-slate-300 text-sm mb-6 leading-relaxed">
        <%= message %>
      </p>

      <div class="space-y-2.5 mb-6 text-xs text-slate-500 border-t border-slate-800/60 pt-4">
        <p><span class="font-medium text-slate-400">Path:</span> <code class="font-mono text-slate-300"><%= path %></code></p>
        <p><span class="font-medium text-slate-400">Time:</span> <span class="font-mono text-slate-300"><%= new Date().toLocaleString() %></span></p>
      </div>

      <!-- Action Button -->
      <a 
        href="/fleets" 
        class="block text-center w-full py-3 rounded-2xl bg-slate-800 hover:bg-slate-700 border border-slate-700/50 hover:border-slate-600 text-white text-sm font-semibold transition-all-300"
      >
        <i class="fa-solid fa-arrow-left mr-2"></i> Return to Dashboard
      </a>
    </div>

    <p class="mt-6 text-xs text-slate-500">FleetPulse Smart Logistics System</p>
  </div>

</body>
</html>
