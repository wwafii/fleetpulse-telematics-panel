<!DOCTYPE html>
<html lang="en" class="h-full bg-slate-950">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — FleetPulse</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Plus Jakarta Sans', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body {
      background-color: #050811;
      background-image: 
        radial-gradient(at 10% 20%, rgba(59, 130, 246, 0.15) 0px, transparent 50%),
        radial-gradient(at 90% 80%, rgba(99, 102, 241, 0.15) 0px, transparent 50%);
    }
    .glass-card {
      background: rgba(15, 23, 42, 0.6);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.05);
    }
  </style>
</head>
<body class="h-full flex items-center justify-center p-4 antialiased">
  
  <div class="w-full max-w-md">
    
    <!-- Header Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex w-14 h-14 rounded-2xl bg-gradient-to-br from-blue-500 to-indigo-600 items-center justify-center shadow-xl shadow-blue-500/25 mb-4">
        <i class="fa-solid fa-truck-fast text-white text-2xl"></i>
      </div>
      <h1 class="text-2xl font-bold tracking-tight text-white">Fleet<span class="text-blue-500">Pulse</span></h1>
      <p class="text-slate-400 text-sm mt-1">Smart Logistics & Telematics Management Panel</p>
    </div>

    <!-- Login Card -->
    <div class="glass-card rounded-3xl p-8 shadow-2xl">
      <h2 class="text-lg font-semibold text-white mb-6">Sign in to Admin Account</h2>

      <% if (error) { %>
        <div class="mb-5 p-4 rounded-2xl bg-red-500/10 border border-red-500/20 text-red-400 text-xs flex items-center gap-3">
          <i class="fa-solid fa-triangle-exclamation text-sm shrink-0"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <form action="/login" method="POST" class="space-y-5">
        
        <!-- Username Field -->
        <div>
          <label for="username" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Username</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-regular fa-user text-xs"></i>
            </span>
            <input 
              type="text" 
              name="username" 
              id="username" 
              required 
              placeholder="e.g. admin" 
              class="w-full pl-10 pr-4 py-3 rounded-2xl bg-slate-900/60 border border-slate-800 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all duration-200"
            >
          </div>
        </div>

        <!-- Password Field -->
        <div>
          <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-2">Password</label>
          <div class="relative">
            <span class="absolute inset-y-0 left-0 pl-3.5 flex items-center text-slate-500">
              <i class="fa-solid fa-lock text-xs"></i>
            </span>
            <input 
              type="password" 
              name="password" 
              id="password" 
              required 
              placeholder="&bull;&bull;&bull;&bull;&bull;&bull;&bull;&bull;" 
              class="w-full pl-10 pr-4 py-3 rounded-2xl bg-slate-900/60 border border-slate-800 text-sm text-white placeholder-slate-500 focus:outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-500/10 transition-all duration-200"
            >
          </div>
        </div>

        <!-- Credentials Helper Info -->
        <div class="p-3.5 rounded-2xl bg-blue-500/5 border border-blue-500/10 text-[11px] text-slate-400 flex items-start gap-2.5">
          <i class="fa-solid fa-circle-info text-blue-400 mt-0.5 shrink-0"></i>
          <div>
            <p class="font-medium text-white mb-0.5">Evaluation Credentials:</p>
            <p>Username: <code class="text-blue-300 font-mono">admin</code></p>
            <p>Password: <code class="text-blue-300 font-mono">adminPassword123</code></p>
          </div>
        </div>

        <!-- Submit Button -->
        <button 
          type="submit" 
          class="w-full py-3.5 rounded-2xl bg-gradient-to-r from-blue-500 to-indigo-600 hover:from-blue-600 hover:to-indigo-700 text-white text-sm font-semibold shadow-lg shadow-blue-500/15 hover:shadow-blue-500/25 transform active:scale-[0.98] transition-all duration-200"
        >
          Sign In
        </button>
      </form>
    </div>

    <!-- Extra meta -->
    <div class="text-center mt-6 text-xs text-slate-500">
      <p>Secure connection. API clients use header <code class="text-slate-400 font-mono">x-api-key</code>.</p>
    </div>

  </div>

</body>
</html>
